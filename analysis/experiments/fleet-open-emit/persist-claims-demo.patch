diff --git a/modules/den/aspects/services/backup/persist-claims-demo.nix b/modules/den/aspects/services/backup/persist-claims-demo.nix
new file mode 100644
index 00000000..afcba327
--- /dev/null
+++ b/modules/den/aspects/services/backup/persist-claims-demo.nix
@@ -0,0 +1,34 @@
+# THROWAWAY DEMO (fleet build-order step 1) — the first OPEN cross-host emit in
+# this tree. Every existing emit (k3s-nodes, bgp-peers, host-addrs,
+# resolved-users) reads only the ENTITY record (host.*/user.*); this one reads
+# the producing peer's RESOLVED nixos `config` — making it config-dependent
+# (resolve.nix:392 `(functionArgs emit) ? config`) and therefore Tier-2/open.
+#
+# Rides services.bgp.spoke (axon-only), where frr is enabled, so
+# `config.users.users.frr.uid` resolves to the deterministic 978 on every axon
+# host. The `nixos` consumer surfaces the collected claims so the cross-host
+# collect actually fires and the result is evaluable for the M1/M2/M3 measurement.
+# Spec: papers/hola-architecture/specs/2026-06-26-fleet-open-emit-demo-design.md
+{ den, ... }:
+{
+  den.aspects.services.backup.persist-claims-demo = {
+    # OPEN emit: `{ host, config, ... }` ⇒ config-dependent ⇒ hasAnyConfigThunk
+    # ⇒ den resolves it against the producer host's resolved config (B′).
+    # `config` here = the PRODUCING peer's nixosSystem config.
+    persist-claims =
+      { host, config, ... }:
+      {
+        host = host.name;
+        path = "/persist/${host.name}/frr";
+        uid = config.users.users.frr.uid; # resolved peer config (978, deterministic) ⇒ Tier-2 read
+      };
+
+    # Consumer: read the collected (local + peer) claims and surface them, so the
+    # scoped collect is demanded (Nix laziness ⇒ nothing forces otherwise).
+    nixos =
+      { persist-claims, ... }:
+      {
+        environment.etc."persist-claims-demo.json".text = builtins.toJSON persist-claims;
+      };
+  };
+}
