diff --git a/modules/den/policies/persist-claims-demo-pipes.nix b/modules/den/policies/persist-claims-demo-pipes.nix
new file mode 100644
index 00000000..ac7d027a
--- /dev/null
+++ b/modules/den/policies/persist-claims-demo-pipes.nix
@@ -0,0 +1,23 @@
+# THROWAWAY DEMO (fleet build-order step 1) — collect policy for the open
+# persist-claims emit. SCOPED `pipe.collect` (env siblings = axon), NOT the
+# `collectAll ({host,...}: true)` Form-B anti-pattern the future S2 lint rejects.
+# `den.schema.host.includes` is a mergeable list (set across 7 files), so this
+# extends it without touching the real pipes.nix.
+# Spec: papers/hola-architecture/specs/2026-06-26-fleet-open-emit-demo-design.md
+{ den, ... }:
+let
+  inherit (den.lib.policy) pipe;
+in
+{
+  den.policies.collect-persist-claims =
+    { host, ... }:
+    [
+      (pipe.from "persist-claims" [
+        (pipe.collect ({ host, ... }: true))
+      ])
+    ];
+
+  den.schema.host.includes = [
+    den.policies.collect-persist-claims
+  ];
+}
