@@ -0,0 +1,8 @@
+# THROWAWAY DEMO (fleet build-order step 1) — Tier-2 OPEN cross-host emit.
+# Per-service persist dir + RESOLVED owner uid (config.users.users.<svc>.uid),
+# the config-dependent cross-host relationship nix-config keeps dormant.
+# Spec: papers/hola-architecture/specs/2026-06-26-fleet-open-emit-demo-design.md
+{
+  den.quirks.persist-claims.description =
+    "Per-service persist dir + resolved owner uid for external backup (Tier-2 open-emit demo)";
+}
